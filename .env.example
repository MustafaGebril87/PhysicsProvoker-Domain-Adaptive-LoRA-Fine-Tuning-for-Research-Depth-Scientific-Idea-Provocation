# Copy to .env and fill in.

# Required for data generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides for generate_pairs.py
NUM_PAIRS=200
K_CANDIDATES=5
SWEETSPOT_LO=0.60
SWEETSPOT_HI=0.85
CROSS_DOMAIN_PROB=0.5
NOVELTY_MIN=7
GEN_MODEL=claude-haiku-4-5
SEED=42

# Optional overrides for finetune.py
BASE_MODEL=Qwen/Qwen3-0.6B
EPOCHS=3
LR=2e-4
LORA_R=16
LORA_ALPHA=32
MAX_SEQ_LEN=768
BATCH_SIZE=1
GRAD_ACCUM=8
